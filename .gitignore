# =============================================================================
# .gitignore — keep personal data, secrets, and large local files out of git.
# =============================================================================

# --- Python virtualenvs (contain absolute paths with your username) ----------
venv/
.venv/
env/
ENV/

# --- Python bytecode / caches -------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
*.egg-info/
build/
dist/

# --- App outputs (binaries pulled at runtime, saved tars, etc.) ---------------
bin/
tars/
*.tar
*.tar.gz
*.tgz

# --- Trivy DB cache -----------------------------------------------------------
.trivy/

# --- Secrets / env files ------------------------------------------------------
.env
.env.*
*.env
*.pem
*.key
*.crt
secrets/
credentials/

# --- IDE / editor metadata ----------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- OS / temp ----------------------------------------------------------------
*.log
*.tmp
*.bak
*.orig

# --- AI assistant / Claude Code local state ----------------------------------
.claude/